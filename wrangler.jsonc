{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "conversionco-mission-control",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "rules": [
    { "type": "Text", "globs": ["**/*.html"], "fallthrough": true }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "conversionco-db",
      "database_id": "fc4094bf-d199-4715-99d4-6d939cdff701"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "CF_ACCOUNT_ID": "71e4892c78ac885973b94c7547987acf"
  }
  // Secrets (set with `wrangler secret put NAME` or in the Cloudflare dashboard):
  //   GHL_TOKEN        - GoHighLevel private integration token
  //   DASH_PASSWORD    - password Tiffany uses to log in to the dashboard
  //   SESSION_SECRET   - random string for signing session cookies
  //   ANTHROPIC_API_KEY (later, for the generation engine)
}
